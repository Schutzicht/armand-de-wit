---
const programs = [
  {
    code: "TR-01",
    title: "Gevaarsbeheersing",
    duur: "1-3 dagen",
    niveau: "Basis tot specialist",
    body: "Leer dreiging herkennen, de-escaleren en handelen wanneer het toch fout dreigt te gaan. Met en zonder hulpmiddelen.",
    tags: ["De-escalatie", "Fysieke weerbaarheid", "Wettelijk kader"],
  },
  {
    code: "TR-02",
    title: "Communicatie onder druk",
    duur: "1-2 dagen",
    niveau: "Alle niveaus",
    body: "Heldere taal, lichaamshouding en team-radio in situaties waarin emoties hoog oplopen. Voor zorg en publieksdomein.",
    tags: ["Verbaal", "Non-verbaal", "Team-comm"],
  },
  {
    code: "TR-03",
    title: "Teamcoordinatie",
    duur: "2 dagen",
    niveau: "Teams van 4-12",
    body: "Werken als eenheid in onvoorspelbare situaties. Rolverdeling, beslismomenten en backup onder druk.",
    tags: ["Rollen", "Beslisbomen", "Backup"],
  },
  {
    code: "TR-04",
    title: "Specialty Team Training",
    duur: "Maatwerk",
    niveau: "Gevorderd",
    body: "Voor teams met een specifieke operationele rol. Scenario's worden ontworpen rond uw werkelijke risicoprofiel.",
    tags: ["Scenario-design", "Live exercise", "After-action"],
  },
];
---
<section id="training" class="relative bg-ink text-paper py-24 md:py-32 overflow-hidden">
  <!-- Photo accent -->
  <div class="absolute right-0 top-0 bottom-0 w-full md:w-1/2 pointer-events-none">
    <img
      src="/img/training-shields.webp"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-30 md:opacity-50 grayscale"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(90deg, rgba(11,12,14,0.95) 0%, rgba(11,12,14,0.7) 30%, rgba(11,12,14,0.4) 100%);"
    ></div>
  </div>

  <div class="absolute inset-0 tac-grid opacity-30 pointer-events-none"></div>

  <div class="container-x relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-16 md:mb-20 items-end">
      <div class="md:col-span-7">
        <div class="tac-eyebrow text-signal mb-6">01 / Training</div>
        <h2 class="text-[clamp(2rem,5.5vw,4.2rem)] font-display font-bold leading-[0.98] tracking-tight text-balance">
          Programma's die <span class="text-signal">de praktijk</span> niet ontkennen.
        </h2>
      </div>
      <div class="md:col-span-5">
        <p class="text-on-dark-soft text-[16px] leading-relaxed">
          Iedere training is scenariogestuurd. Geen theoriedagen met een dunne praktijkmiddag,
          maar herhaalde blootstelling onder gecontroleerde spanning, met directe feedback.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-ink-line border hairline-dark rounded-sm overflow-hidden">
      {programs.map((p) => (
        <article class="group bg-ink-2 p-7 md:p-9 hover:bg-ink-3 transition-colors duration-300 flex flex-col">
          <header class="flex items-center justify-between mb-6">
            <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute">{p.code}</span>
            <span class="inline-flex items-center justify-center w-9 h-9 rounded-full border hairline-dark group-hover:border-signal group-hover:text-signal transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                <path d="M7 17L17 7"/>
                <path d="M7 7h10v10"/>
              </svg>
            </span>
          </header>

          <h3 class="text-[1.8rem] md:text-[2.2rem] font-display font-bold tracking-tight leading-none">
            {p.title}
          </h3>

          <p class="mt-4 text-[15px] leading-relaxed text-on-dark-soft max-w-md">{p.body}</p>

          <dl class="mt-8 grid grid-cols-2 gap-4 text-[12px] font-mono uppercase tracking-[0.14em] pt-6 border-t hairline-dark">
            <div>
              <dt class="text-on-dark-mute mb-1">Duur</dt>
              <dd class="text-paper">{p.duur}</dd>
            </div>
            <div>
              <dt class="text-on-dark-mute mb-1">Niveau</dt>
              <dd class="text-paper">{p.niveau}</dd>
            </div>
          </dl>

          <ul class="mt-6 flex flex-wrap gap-1.5">
            {p.tags.map((t) => (
              <li class="px-2.5 py-1 text-[11px] font-mono uppercase tracking-[0.14em] border hairline-dark text-on-dark-soft">
                {t}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-between gap-4 pt-8 border-t hairline-dark">
      <p class="text-on-dark-soft text-[15px] max-w-lg">
        Geen passend programma in het overzicht? We ontwerpen op aanvraag een traject rond uw exacte risicoprofiel.
      </p>
      <a href="#contact" class="btn btn-signal">
        Vraag maatwerk aan
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>
