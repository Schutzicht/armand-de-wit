---
const deliverables = [
  { label: "Veiligheidsbeleid", body: "Praktisch document dat uw mensen ook echt gebruiken." },
  { label: "Risicoanalyse", body: "Concrete kwetsbaarheden, geen abstracte matrices." },
  { label: "Trainingsplan", body: "Welke vaardigheid voor wie, met welke frequentie." },
  { label: "Materiaaladvies", body: "Welke uitrusting, waarom, en wat het oplevert." },
];
---
<section id="advies" class="relative bg-paper py-24 md:py-32 overflow-hidden">
  <div class="container-x relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">

      <div class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="tac-eyebrow text-signal mb-6">02 / Advies</div>
        <h2 class="text-[clamp(2rem,5vw,3.8rem)] font-display font-bold leading-[0.98] tracking-tight text-balance">
          Risicobeheersing <br/><span class="text-signal">op maat.</span>
        </h2>
        <p class="mt-6 text-[16px] md:text-[17px] text-on-paper-soft leading-relaxed max-w-md">
          Veiligheid is meer dan een training of een vest. Het is een samenhangend systeem van beleid,
          mensen en middelen. Wij brengen die drie samen in een aanpak die werkt voor uw organisatie,
          niet voor een spreadsheet.
        </p>

        <div class="mt-8 grid grid-cols-3 gap-4 pt-8 border-t hairline">
          <div>
            <div class="stat-num text-[2rem] text-on-paper">48u</div>
            <div class="mt-1 text-[11px] font-mono uppercase tracking-[0.16em] text-on-paper-mute">reactietijd offerte</div>
          </div>
          <div>
            <div class="stat-num text-[2rem] text-on-paper">100%</div>
            <div class="mt-1 text-[11px] font-mono uppercase tracking-[0.16em] text-on-paper-mute">onafhankelijk</div>
          </div>
          <div>
            <div class="stat-num text-[2rem] text-on-paper">0</div>
            <div class="mt-1 text-[11px] font-mono uppercase tracking-[0.16em] text-on-paper-mute">standaardrapporten</div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="relative overflow-hidden rounded-sm border hairline bg-ink">
          <img
            src="/img/advies-room.webp"
            alt="Vergaderzaal voor strategisch veiligheidsadvies"
            class="w-full h-[20rem] md:h-[28rem] object-cover grayscale"
            loading="lazy"
          />
          <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 50%, rgba(11,12,14,0.7));"></div>
          <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between text-paper">
            <div>
              <div class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute mb-1">Sessie /02</div>
              <div class="font-display text-[18px] md:text-[22px] font-semibold leading-tight">Strategische evaluatie<br/>op directieniveau.</div>
            </div>
            <div class="hidden md:flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.18em] text-on-dark-soft">
              <span class="w-1.5 h-1.5 bg-signal rounded-full anim-pulse-dot"></span>
              Live case
            </div>
          </div>
        </div>

        <ul class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-px bg-paper-line border hairline rounded-sm overflow-hidden">
          {deliverables.map((d, i) => (
            <li class="bg-paper p-6 flex gap-4">
              <span class="font-mono text-[12px] tracking-[0.18em] text-signal pt-0.5">0{i + 1}</span>
              <div>
                <div class="font-display font-bold text-[17px] tracking-tight">{d.label}</div>
                <p class="mt-1 text-[14px] text-on-paper-soft leading-relaxed">{d.body}</p>
              </div>
            </li>
          ))}
        </ul>

        <a href="#contact" class="mt-10 inline-flex items-center gap-2 font-display font-semibold text-[15px] text-on-paper hover:text-signal transition-colors group">
          Plan een intakegesprek
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-full border hairline group-hover:border-signal transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
