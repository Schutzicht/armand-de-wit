---
---
<section id="contact" class="relative bg-ink text-paper py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 tac-grid opacity-40 pointer-events-none"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(60% 60% at 80% 30%, rgba(226, 90, 28, 0.18), transparent 60%);"
  ></div>

  <div class="container-x relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

      <div class="lg:col-span-6">
        <div class="tac-eyebrow text-signal mb-6">Klaar voor een gesprek</div>
        <h2 class="text-[clamp(2.2rem,6vw,5rem)] font-display font-bold leading-[0.95] tracking-tight text-balance">
          Uw veiligheid <br/>begint <span class="text-signal">hier.</span>
        </h2>
        <p class="mt-8 text-[17px] md:text-[19px] text-on-dark-soft leading-relaxed max-w-lg">
          Bel direct of laat ons weten waar u tegen aanloopt. Binnen 48 uur ontvangt u een voorstel of
          een tijdsblok voor een vrijblijvend intakegesprek.
        </p>

        <div class="mt-10 space-y-1">
          <a href="tel:+31623734238" class="group block py-5 border-t hairline-dark hover:border-signal transition-colors">
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute mb-1">Direct contact</div>
                <div class="font-display font-bold text-[1.8rem] md:text-[2.2rem] tracking-tight leading-none group-hover:text-signal transition-colors">
                  +31 6 23 73 42 38
                </div>
              </div>
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-full border hairline-dark group-hover:border-signal group-hover:text-signal transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              </span>
            </div>
          </a>

          <a href="mailto:info@armanddewit.com" class="group block py-5 border-t hairline-dark hover:border-signal transition-colors">
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute mb-1">Email</div>
                <div class="font-display font-bold text-[1.4rem] md:text-[1.7rem] tracking-tight leading-none group-hover:text-signal transition-colors break-all">
                  info@armanddewit.com
                </div>
              </div>
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-full border hairline-dark group-hover:border-signal group-hover:text-signal transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
            </div>
          </a>

          <a href="https://wa.me/31623734238" target="_blank" rel="noopener" class="group block py-5 border-t border-b hairline-dark hover:border-signal transition-colors">
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute mb-1">Snelle vraag</div>
                <div class="font-display font-bold text-[1.4rem] md:text-[1.7rem] tracking-tight leading-none group-hover:text-signal transition-colors">
                  Stuur WhatsApp
                </div>
              </div>
              <span class="inline-flex items-center justify-center w-11 h-11 rounded-full border hairline-dark group-hover:border-signal group-hover:text-signal transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 5 4.4.7.3 1.2.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.3-.6-.4z"/><path d="M20.5 3.5C18.3 1.2 15.3 0 12 0 5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6L0 24l6.2-1.6c1.7.9 3.7 1.5 5.8 1.5 6.6 0 12-5.4 12-12 0-3.3-1.2-6.3-3.5-8.4zM12 22c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-3.7 1 1-3.6-.2-.4C2.5 15.8 2 13.9 2 12 2 6.5 6.5 2 12 2c2.7 0 5.2 1 7.1 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 10-10 10z"/></svg>
              </span>
            </div>
          </a>
        </div>
      </div>

      <div class="lg:col-span-6">
        <form
          class="relative bg-ink-2 border hairline-dark rounded-sm p-7 md:p-9"
          aria-label="Aanvraagformulier"
        >
          <div class="flex items-center justify-between mb-8">
            <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute">FORM /01 - INTAKE</span>
            <span class="flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.18em] text-signal">
              <span class="w-1.5 h-1.5 bg-signal rounded-full anim-pulse-dot"></span>
              Reactie binnen 48u
            </span>
          </div>

          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <label class="block">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute">Naam *</span>
                <input
                  type="text"
                  required
                  class="mt-1.5 block w-full bg-transparent border-0 border-b hairline-dark py-2 text-paper placeholder:text-on-dark-mute focus:border-signal transition-colors"
                  placeholder="Voor- en achternaam"
                />
              </label>
              <label class="block">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute">Organisatie</span>
                <input
                  type="text"
                  class="mt-1.5 block w-full bg-transparent border-0 border-b hairline-dark py-2 text-paper placeholder:text-on-dark-mute focus:border-signal transition-colors"
                  placeholder="Naam van uw organisatie"
                />
              </label>
              <label class="block">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute">Email *</span>
                <input
                  type="email"
                  required
                  class="mt-1.5 block w-full bg-transparent border-0 border-b hairline-dark py-2 text-paper placeholder:text-on-dark-mute focus:border-signal transition-colors"
                  placeholder="naam@organisatie.nl"
                />
              </label>
              <label class="block">
                <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute">Telefoon</span>
                <input
                  type="tel"
                  class="mt-1.5 block w-full bg-transparent border-0 border-b hairline-dark py-2 text-paper placeholder:text-on-dark-mute focus:border-signal transition-colors"
                  placeholder="06 ..."
                />
              </label>
            </div>

            <fieldset>
              <legend class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute mb-3">
                Interesse
              </legend>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                {["Training", "Advies", "TacSupply", "Overig"].map((opt) => (
                  <label class="cursor-pointer">
                    <input type="checkbox" name="interest" value={opt} class="peer sr-only"/>
                    <span class="block px-3 py-2.5 text-[12px] font-mono uppercase tracking-[0.14em] text-on-dark-soft border hairline-dark text-center peer-checked:bg-signal peer-checked:border-signal peer-checked:text-paper hover:border-signal transition-colors">
                      {opt}
                    </span>
                  </label>
                ))}
              </div>
            </fieldset>

            <label class="block">
              <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-on-dark-mute">Uw vraag</span>
              <textarea
                rows="4"
                class="mt-1.5 block w-full bg-transparent border-0 border-b hairline-dark py-2 text-paper placeholder:text-on-dark-mute focus:border-signal transition-colors resize-none"
                placeholder="Vertel kort waar u tegen aanloopt..."
              ></textarea>
            </label>

            <button type="submit" class="btn btn-signal w-full justify-center mt-4">
              Verstuur aanvraag
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
            </button>

            <p class="text-[11px] font-mono uppercase tracking-[0.14em] text-on-dark-mute text-center">
              We reageren binnen 2 werkdagen / Vertrouwelijk behandeld
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
