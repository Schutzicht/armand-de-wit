---
import "../styles/global.css";

const disclaimers = [
  {
    label: "Concept",
    body: "Dit is een visueel concept. Layout, kleurgebruik en interactie staan, definitieve keuzes nog niet.",
  },
  {
    label: "Beeldmateriaal",
    body: "De foto's zijn placeholders, deels overgenomen van de huidige site. Definitieve fotografie volgt.",
  },
  {
    label: "Teksten",
    body: "Alle copy is voorbeeldtekst om de toon te demonstreren. Eindredactie gebeurt samen met Armand.",
  },
  {
    label: "Cijfers & cases",
    body: "Statistieken (17+ jaar, 2.400 deelnemers, 9,4/10) en testimonials zijn fictief en alleen ter illustratie.",
  },
  {
    label: "Functionaliteit",
    body: "Het contactformulier en navigatielinks zijn nog niet gekoppeld. Werkt straks volledig in productie.",
  },
];
---
<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content="Demo briefing - A New Level Of Training voor Armand de Wit" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>Demo briefing - Armand de Wit</title>
  </head>
  <body class="bg-ink text-paper">
    <main class="relative min-h-[100svh] flex flex-col overflow-hidden">
      <!-- Background layers -->
      <div class="absolute inset-0 tac-grid opacity-40 pointer-events-none"></div>
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(55% 50% at 20% 10%, rgba(226, 90, 28, 0.18), transparent 60%), radial-gradient(60% 60% at 90% 100%, rgba(63, 74, 58, 0.30), transparent 70%);"
      ></div>
      <svg
        class="absolute -right-40 -top-20 w-[55rem] opacity-[0.08] pointer-events-none"
        viewBox="0 0 800 800"
        fill="none"
        aria-hidden="true"
      >
        {Array.from({ length: 10 }).map((_, i) => {
          const r = 80 + i * 32;
          return <circle cx="400" cy="400" r={r} stroke="#F4F2EC" stroke-width="0.7" />;
        })}
        <line x1="0" y1="400" x2="800" y2="400" stroke="#F4F2EC" stroke-width="0.7"/>
        <line x1="400" y1="0" x2="400" y2="800" stroke="#F4F2EC" stroke-width="0.7"/>
      </svg>

      <!-- Top bar -->
      <header class="relative container-x pt-6 md:pt-8">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <img
              src="/img/logo-adw.webp"
              alt="A New Level Of Training logo"
              width="32"
              height="32"
              class="shrink-0"
              style="height:32px;width:auto"
            />
            <div class="font-display font-bold leading-tight tracking-tight text-[12px]">
              A NEW LEVEL OF TRAINING<br/>
              <span class="font-mono font-medium text-[10px] tracking-[0.2em] opacity-70">BY ARMAND DE WIT</span>
            </div>
          </div>
          <div class="hidden sm:flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.2em] text-on-dark-mute">
            <span class="inline-block w-2 h-2 rounded-full bg-signal anim-pulse-dot"></span>
            Demo briefing
          </div>
        </div>
      </header>

      <!-- Main briefing -->
      <div class="relative container-x flex-1 flex items-center py-10 md:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 w-full items-start">

          <!-- Left: title + intro + CTA -->
          <div class="lg:col-span-7">
            <div class="tac-eyebrow text-signal mb-6">Briefing /00 - Lees eerst dit</div>
            <h1 class="display-hero text-[clamp(2.4rem,7.5vw,5.6rem)] text-balance">
              Voor je <span class="text-signal">verder klikt.</span>
            </h1>
            <p class="mt-7 md:mt-9 text-[16px] md:text-[18px] text-on-dark leading-relaxed text-pretty max-w-xl">
              Wat je zo gaat zien is een <strong class="text-paper">demo-website</strong> die ik heb gebouwd om
              een visuele richting te laten zien voor A New Level Of Training. Het is geen live site, geen
              definitief ontwerp en geen vrijgegeven communicatie.
            </p>
            <p class="mt-4 text-[15px] md:text-[16px] text-on-dark-soft leading-relaxed max-w-xl">
              De aanpak, het kleurgebruik en de structuur zijn doordacht. De inhoud is dat
              <em class="not-italic text-paper">nog niet</em>. Lees onderstaande disclaimers door zodat we het
              over hetzelfde hebben als we straks de demo bekijken.
            </p>

            <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-4">
              <a href="/demo" class="btn btn-signal !py-4 !px-6 text-[15px]">
                Ja, ik snap het - bekijk de demo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
              </a>
              <span class="text-[12px] font-mono uppercase tracking-[0.18em] text-on-dark-mute">
                Geschatte leestijd /1 min
              </span>
            </div>

            <div class="mt-12 pt-8 border-t hairline-dark text-[12px] font-mono uppercase tracking-[0.18em] text-on-dark-mute">
              <div class="flex flex-wrap gap-x-6 gap-y-2">
                <span>Gemaakt door / Jorik Schut</span>
                <span class="text-signal">/</span>
                <span>Concept v0.1 / {new Date().toLocaleDateString("nl-NL", { day: "2-digit", month: "short", year: "numeric" })}</span>
              </div>
            </div>
          </div>

          <!-- Right: disclaimer card -->
          <div class="lg:col-span-5">
            <div class="relative border hairline-dark bg-ink-2/60 backdrop-blur-sm rounded-sm p-6 md:p-8 corner-mark text-paper">
              <div class="flex items-center justify-between mb-7">
                <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-on-dark-mute">DISCLAIMERS /05</span>
                <span class="flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.18em] text-signal">
                  <span class="w-1.5 h-1.5 bg-signal rounded-full anim-pulse-dot"></span>
                  Belangrijk
                </span>
              </div>

              <ul class="divide-y hairline-dark">
                {disclaimers.map((d, i) => (
                  <li class="py-4 first:pt-0 last:pb-0 flex gap-4">
                    <span class="font-mono text-[12px] tracking-[0.18em] text-signal pt-0.5 shrink-0">0{i + 1}</span>
                    <div>
                      <div class="font-display font-semibold text-[15px] tracking-tight">{d.label}</div>
                      <p class="mt-1 text-[13.5px] text-on-dark-soft leading-relaxed">{d.body}</p>
                    </div>
                  </li>
                ))}
              </ul>

              <div class="mt-8 pt-6 border-t hairline-dark flex items-start gap-3">
                <svg class="shrink-0 mt-0.5 text-signal" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="13"/>
                  <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <p class="text-[13px] text-on-dark-soft leading-relaxed">
                  Deel deze link niet zonder overleg. De demo is bedoeld als gespreksstuk, niet als publicatie.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <footer class="relative container-x pb-6 md:pb-8 border-t hairline-dark pt-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 text-[11px] font-mono uppercase tracking-[0.18em] text-on-dark-mute">
          <span>Demo / A New Level Of Training</span>
          <a href="/demo" class="inline-flex items-center gap-2 hover:text-signal transition-colors">
            Skip naar demo
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </footer>
    </main>
  </body>
</html>
