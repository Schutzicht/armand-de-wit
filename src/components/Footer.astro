---
import Logo from "./Logo.astro";
---
<footer class="bg-ink text-on-dark-soft pt-20 pb-10 relative overflow-hidden">
  <div class="absolute inset-0 tac-grid opacity-50 pointer-events-none"></div>
  <div class="container-x relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <div class="md:col-span-5">
        <Logo variant="paper" />
        <p class="mt-6 max-w-sm text-on-dark-soft text-[15px] leading-relaxed">
          A New Level Of Training begeleidt professionals met publiekscontact richting zelfbeheersing,
          praktische vaardigheid en weloverwogen beslissingen op kritieke momenten.
        </p>
        <div class="mt-8 flex items-center gap-2 text-[12px] font-mono tracking-[0.18em] uppercase text-on-dark-mute">
          <span class="inline-block w-2 h-2 rounded-full bg-signal anim-pulse-dot"></span>
          Operationeel sinds 2009
        </div>
      </div>

      <div class="md:col-span-3">
        <h4 class="tac-eyebrow text-on-dark-mute mb-5">Diensten</h4>
        <ul class="space-y-2.5 text-[14px]">
          <li><a href="#training" class="hover:text-paper transition-colors">Training & opleiding</a></li>
          <li><a href="#advies" class="hover:text-paper transition-colors">Veiligheidsadvies</a></li>
          <li><a href="#tacsupply" class="hover:text-paper transition-colors">TacSupply</a></li>
          <li><a href="#aanpak" class="hover:text-paper transition-colors">Onze aanpak</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="tac-eyebrow text-on-dark-mute mb-5">Contact</h4>
        <ul class="space-y-3 text-[14px]">
          <li>
            <a href="mailto:info@armanddewit.com" class="inline-flex items-center gap-2 hover:text-paper transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              info@armanddewit.com
            </a>
          </li>
          <li>
            <a href="tel:+31623734238" class="inline-flex items-center gap-2 hover:text-paper transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              +31 (0)6 23 73 42 38
            </a>
          </li>
          <li>
            <a href="https://wa.me/31623734238" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-paper transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.8-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3.1 5 4.4.7.3 1.2.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.4.2-.7.2-1.3.2-1.4-.1-.2-.3-.3-.6-.4z"/><path d="M20.5 3.5C18.3 1.2 15.3 0 12 0 5.4 0 0 5.4 0 12c0 2.1.6 4.2 1.6 6L0 24l6.2-1.6c1.7.9 3.7 1.5 5.8 1.5 6.6 0 12-5.4 12-12 0-3.3-1.2-6.3-3.5-8.4zM12 22c-1.9 0-3.7-.5-5.3-1.4l-.4-.2-3.7 1 1-3.6-.2-.4C2.5 15.8 2 13.9 2 12 2 6.5 6.5 2 12 2c2.7 0 5.2 1 7.1 2.9 1.9 1.9 2.9 4.4 2.9 7.1 0 5.5-4.5 10-10 10z"/></svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-paper transition-colors">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 2h-17C2.7 2 2 2.7 2 3.5v17c0 .8.7 1.5 1.5 1.5h17c.8 0 1.5-.7 1.5-1.5v-17c0-.8-.7-1.5-1.5-1.5zM8 19H5V9h3v10zM6.5 7.7c-1 0-1.7-.8-1.7-1.7s.8-1.7 1.7-1.7 1.7.8 1.7 1.7-.7 1.7-1.7 1.7zM19 19h-3v-5.3c0-1.4-.5-2.1-1.6-2.1-1.2 0-1.8.8-1.8 2.1V19h-3V9h2.9v1.3c.6-1 1.6-1.5 2.9-1.5 2.1 0 3.6 1.3 3.6 4V19z"/></svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t hairline-dark flex flex-col md:flex-row justify-between gap-4 text-[12px] font-mono uppercase tracking-[0.16em] text-on-dark-mute">
      <p>&copy; {new Date().getFullYear()} A New Level Of Training / Armand de Wit</p>
      <div class="flex flex-wrap gap-x-6 gap-y-1">
        <a href="#" class="hover:text-paper transition-colors">Privacy</a>
        <a href="#" class="hover:text-paper transition-colors">Algemene voorwaarden</a>
        <span>KvK 12.34.56.78</span>
      </div>
    </div>
  </div>
</footer>
